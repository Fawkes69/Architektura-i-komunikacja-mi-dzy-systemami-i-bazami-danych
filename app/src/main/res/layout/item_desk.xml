<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeColor="#EFEFEF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Zdjęcie biura/sali -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/desk_image"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:src="@drawable/ic_office_placeholder"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.TopRounded" />

            <!-- Ulubiony - Float Button -->
            <ImageButton
                android:id="@+id/favorite_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_favorite_outline"
                android:contentDescription="@string/add_to_favorites"
                android:scaleType="centerInside"
                android:background="@drawable/bg_circle_white"
                android:layout_marginTop="-20dp"
                android:layout_marginEnd="12dp"
                android:layout_gravity="top|end" />

            <!-- Informacje o biurku -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Nazwa biuska -->
                <TextView
                    android:id="@+id/desk_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Biuro A - Stanowisko 1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Lokalizacja -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_location"
                        android:tint="#999999"
                        android:contentDescription="@string/location" />

                    <TextView
                        android:id="@+id/desk_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Piętro 2"
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:layout_marginStart="6dp" />

                </LinearLayout>

                <!-- Rating -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="12dp">

                    <RatingBar
                        android:id="@+id/desk_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:rating="4.5"
                        android:isIndicator="true"
                        android:scaleX="0.8"
                        android:scaleY="0.8"
                        android:transformPivotX="0dp"
                        android:transformPivotY="0dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(24 oceny)"
                        android:textSize="11sp"
                        android:textColor="#999999"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Cena i przycisk rezerwacji -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/desk_price"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="45 zł/dzień"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/reserve_button"
                        android:layout_width="120dp"
                        android:layout_height="40dp"
                        android:text="@string/reserve"
                        android:textSize="12sp"
                        app:cornerRadius="8dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>